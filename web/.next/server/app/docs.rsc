nv"}]]}],["$","a","operate",{"href":"#operate","className":"docs-sidebar-link","children":[["$","span",null,{"className":"font-mono text-[0.72rem] uppercase tracking-[0.16em]","children":"Operate"}],["$","span",null,{"className":"font-copy text-sm leading-6","children":"Health, limits, retention"}]]}],["$","a","security",{"href":"#security","className":"docs-sidebar-link","children":[["$","span",null,{"className":"font-mono text-[0.72rem] uppercase tracking-[0.16em]","children":"Security"}],["$","span",null,{"className":"font-copy text-sm leading-6","children":"Hardening and threat model"}]]}],["$","a","reference",{"href":"#reference","className":"docs-sidebar-link","children":[["$","span",null,{"className":"font-mono text-[0.72rem] uppercase tracking-[0.16em]","children":"Reference"}],["$","span",null,{"className":"font-copy text-sm leading-6","children":"API, SDK, repo map"}]]}]]]}]}],["$","div",null,{"className":"space-y-16","children":[["$","section",null,{"id":"start","className":"section-rule scroll-mt-28","children":["$","div",null,{"className":"grid gap-6 xl:grid-cols-[12rem_1fr]","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Start"}],["$","h2",null,{"className":"text-3xl tracking-[-0.06em]","children":"Use Velarix close to execution"}]]}],["$","div",null,{"className":"space-y-8","children":[["$","p",null,{"className":"copy-tone font-copy max-w-3xl text-xl leading-8","children":"The strongest integration path in this repo is not generic memory. It is approval integrity: capture facts, derive a recommendation, create a decision, and re-check before the action fires."}],[["$","div",null,{"className":"grid gap-4 lg:grid-cols-2","children":[["$","article","What the repo ships today",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"What the repo ships today"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"Go API, first-class decisions, session facts, invalidation, explanation endpoints, a Python SDK, a demo approval workflow, local Badger storage, and a production path centered on Postgres plus optional Redis coordination."}]]}],["$","article","What it does not claim",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"What it does not claim"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"This repo is not a finished finance-ops SaaS, not a generic memory platform, and not an audited compliance product. The docs below stay honest about current delivery versus production direction."}]]}]]}],["$","div",null,{"className":"space-y-6","children":[["$","article","Run the API locally",{"className":"grid gap-4 border-t border-[var(--line)] pt-6 lg:grid-cols-[12rem_1fr] lg:gap-8","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Step 01"}],["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Run the API locally"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"className":"copy-tone font-copy text-lg leading-8","children":"The maintained local path is Go plus Badger in dev mode. This is the fastest way to explore the approval-guardrail flow end to end."}],["$","div",null,{"className":"dark-surface code-panel p-5 md:p-6","children":["$","pre",null,{"children":"export VELARIX_ENV=dev\nexport VELARIX_API_KEY=dev-admin-key\nexport VELARIX_BADGER_PATH=\"$(mktemp -d)\"\n\ngo run main.go"}]}]]}]]}],["$","article","Record approval facts",{"className":"grid gap-4 border-t border-[var(--line)] pt-6 lg:grid-cols-[12rem_1fr] lg:gap-8","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Step 02"}],["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Record approval facts"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"className":"copy-tone font-copy text-lg leading-8","children":"Use the Python client to open a session, assert direct observations, derive the recommendation, and persist a decision against that fact graph."}],["$","div",null,{"className":"dark-surface code-panel p-5 md:p-6","children":["$","pre",null,{"children":"from velarix.client import VelarixClient\n\nclient = VelarixClient(\n    base_url=\"http://localhost:8080\",\n    api_key=\"dev-admin-key\",\n)\n\nsession = client.session(\"payment_approval_001\")\nsession.observe(\"vendor_verified\", {\"vendor_id\": \"vendor-17\"})\nsession.observe(\"invoice_approved\", {\"invoice_id\": \"inv-1042\"})\nsession.observe(\"budget_available\", {\"cost_center\": \"ENG-01\"})\n\nsession.derive(\n    \"decision.release_payment\",\n    [[\"vendor_verified\", \"invoice_approved\", \"budget_available\"]],\n    {\"summary\": \"Payment can be released\"},\n)"}]}]]}]]}],["$","article","Check before executing",{"className":"grid gap-4 border-t border-[var(--line)] pt-6 lg:grid-cols-[12rem_1fr] lg:gap-8","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Step 03"}],["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Check before executing"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"className":"copy-tone font-copy text-lg leading-8","children":"The product story is execution integrity. Call execute-check immediately before the side effect, then execute only if the decision is still valid."}],["$","div",null,{"className":"dark-surface code-panel p-5 md:p-6","children":["$","pre",null,{"children":"decision = session.create_decision(\n    \"payment_release\",\n    fact_id=\"decision.release_payment\",\n    subject_ref=\"inv-1042\",\n    target_ref=\"vendor-17\",\n    dependency_fact_ids=[\n        \"vendor_verified\",\n        \"invoice_approved\",\n        \"budget_available\",\n    ],\n)\n\ncheck = session.execute_check(decision[\"decision_id\"])\nif check[\"executable\"]:\n    session.execute_decision(decision[\"decision_id\"])"}]}]]}]]}]]}]]]}]]}]}],["$","section",null,{"id":"runtime","className":"section-rule scroll-mt-28","children":["$","div",null,{"className":"grid gap-6 xl:grid-cols-[12rem_1fr]","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Runtime"}],["$","h2",null,{"className":"text-3xl tracking-[-0.06em]","children":"Facts, decisions, and explanations"}]]}],["$","div",null,{"className":"space-y-8","children":[["$","p",null,{"className":"copy-tone font-copy max-w-3xl text-xl leading-8","children":"The repo models approval state as a fact graph. Decisions bind an action to that graph. Explanation surfaces are there so stale execution can be understood and debugged instead of merely denied."}],[["$","div",null,{"className":"grid gap-4 md:grid-cols-2","children":[["$","article","Facts and derived facts",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Facts and derived facts"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"A fact can be asserted directly or derived from other facts through OR-of-AND justification sets. Root observations and derived conclusions live in the same session graph."}]]}],["$","article","Decisions and dependency snapshots",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Decisions and dependency snapshots"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"A decision is created from a fact and stores the dependencies that justified the recommendation. That snapshot is checked again before execution."}]]}],["$","article","Invalidation and pruning",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Invalidation and pruning"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"When a root fact changes, downstream conclusions can collapse if they no longer have valid support. The theory and benchmark docs describe this as O(1) pruning through dominator-style ancestry checks."}]]}],["$","article","Explanation and counterfactuals",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Explanation and counterfactuals"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"The explain surfaces do more than dump state. They expose the chain of belief, blocked dependencies, and counterfactual reasoning about what would change if a fact disappeared."}]]}]]}],["$","div",null,{"className":"space-y-4 border-t border-[var(--line)] pt-6","children":[["$","p",null,{"className":"eyebrow","children":"Execution flow"}],["$","div",null,{"className":"grid gap-4 md:grid-cols-2 xl:grid-cols-3","children":[["$","article","1. Observe",{"className":"surface p-5","children":[["$","h3",null,{"className":"text-xl tracking-[-0.04em]","children":"1. Observe"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-base leading-7","children":"Collect the approval facts that matter: vendor verification, invoice approval, policy sign-off, budget, access grant, or other hard prerequisites."}]]}],["$","article","2. Derive",{"className":"surface p-5","children":[["$","h3",null,{"className":"text-xl tracking-[-0.04em]","children":"2. Derive"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-base leading-7","children":"Create the derived recommendation that represents the action you want to take. This is where the graph becomes operational instead of descriptive."}]]}],["$","article","3. Decide",{"className":"surface p-5","children":[["$","h3",null,{"className":"text-xl tracking-[-0.04em]","children":"3. Decide"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-base leading-7","children":"Persist a first-class decision with subject references, targets, policy metadata, and dependency fact ids so execution is bound to a stable snapshot."}]]}],["$","article","4. Re-check",{"className":"surface p-5","children":[["$","h3",null,{"className":"text-xl tracking-[-0.04em]","children":"4. Re-check"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-base leading-7","children":"Call execute-check immediately before money moves, access changes, or state mutates. If dependencies went stale, the action should stop here."}]]}],["$","article","5. Explain",{"className":"surface p-5","children":[["$","h3",null,{"className":"text-xl tracking-[-0.04em]","children":"5. Explain"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-base leading-7","children":"If a decision is blocked, inspect why-blocked, impact, explanation, history, and lineage. The repo treats operator visibility as part of the product, not an afterthought."}]]}]]}]]}]]]}]]}]}],["$","section",null,{"id":"deploy","className":"section-rule scroll-mt-28","children":["$","div",null,{"className":"grid gap-6 xl:grid-cols-[12rem_1fr]","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Deploy"}],["$","h2",null,{"className":"text-3xl tracking-[-0.06em]","children":"Treat local and production paths differently"}]]}],["$","div",null,{"className":"space-y-8","children":[["$","p",null,{"className":"copy-tone font-copy max-w-3xl text-xl leading-8","children":"The codebase is explicit about this: Badger is the local adapter, not the product architecture. Production-like deployments should use Postgres, Redis, secure auth material, and a separately deployed frontend."}],[["$","div",null,{"className":"grid gap-4 md:grid-cols-3","children":[["$","article","Local development",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Local development"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"Badger is the local adapter. Use it for tests, demos, and fast iteration. It should not define the long-term production shape of the service."}]]}],["$","article","Production direction",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Production direction"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"The target runtime is Postgres as the system of record, Redis for idempotency and rate limiting, and rebuildable in-memory engine caches instead of a permanently warm single node."}]]}],["$","article","Hosted console path",{"className":"surface p-6","children":[["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Hosted console path"}],["$","p",null,{"className":"copy-tone mt-3 font-copy text-lg leading-8","children":"The Next.js app in web/ points to the public API through NEXT_PUBLIC_VELARIX_API_URL. The private control-plane folder describes billing, provisioning, and infrastructure direction for Velarix Cloud."}]]}]]}],["$","div",null,{"className":"space-y-6","children":[["$","article","Containerize the API",{"className":"grid gap-4 border-t border-[var(--line)] pt-6 lg:grid-cols-[12rem_1fr] lg:gap-8","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Build"}],["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Containerize the API"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"className":"copy-tone font-copy text-lg leading-8","children":"The root Dockerfile currently builds the Go binary and starts it in lite mode by default. For production, run without --lite so the authenticated routes are mounted."}],["$","div",null,{"className":"dark-surface code-panel p-5 md:p-6","children":["$","pre",null,{"children":"docker build -t velarix-engine .\ndocker run --rm -p 8080:8080 \\\n  -e VELARIX_ENV=prod \\\n  -e VELARIX_STORE_BACKEND=postgres \\\n  -e VELARIX_POSTGRES_DSN=\"postgres://...\" \\\n  -e VELARIX_REDIS_URL=\"redis://...\" \\\n  -e VELARIX_JWT_SECRET=\"replace-me\" \\\n  -e VELARIX_ENCRYPTION_KEY=\"replace-me\" \\\n  velarix-engine ./velarix"}]}]]}]]}],["$","article","Point the console at the API",{"className":"grid gap-4 border-t border-[var(--line)] pt-6 lg:grid-cols-[12rem_1fr] lg:gap-8","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Frontend"}],["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Point the console at the API"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"className":"copy-tone font-copy text-lg leading-8","children":"The web app is a separate deployment unit. After your API is live, inject its public base URL into the Next.js frontend before building or deploying web/."}],["$","div",null,{"className":"dark-surface code-panel p-5 md:p-6","children":["$","pre",null,{"children":"cd web\nexport NEXT_PUBLIC_VELARIX_API_URL=\"https://api.example.com\"\nnpm run build"}]}]]}]]}],["$","article","Use the documented GCP path if you need managed infra",{"className":"grid gap-4 border-t border-[var(--line)] pt-6 lg:grid-cols-[12rem_1fr] lg:gap-8","children":[["$","div",null,{"className":"space-y-2","children":[["$","p",null,{"className":"eyebrow","children":"Cloud"}],["$","h3",null,{"className":"text-2xl tracking-[-0.05em]","children":"Use the documented GCP path if you need managed infra"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"className":"copy-tone font-copy text-lg leading-8","children":"The repo already includes a deployment guide centered on Cloud Run, Cloud SQL, and Memorystore, with Vercel or a second Run service for the frontend."}],["$","div",null,{"className":"dark-surface code-panel p-5 md:p-6","children":["$","pre",null,{"children":"gcloud run deploy velarix-api \\\n  --image gc