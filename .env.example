# Velarix Environment Variables

# Environment mode.
# Use dev for local development. Non-dev deployments must also set VELARIX_JWT_SECRET.
VELARIX_ENV=dev

# Admin API key for Bearer auth on local/dev routes.
VELARIX_API_KEY=dev-admin-key

# Backend selection:
# - badger: local embedded adapter for development/tests
# - postgres: shared durable backend
VELARIX_STORE_BACKEND=badger

# Local Badger path. Useful to isolate dev/test runs.
VELARIX_BADGER_PATH=velarix.data

# Encryption at Rest (BadgerDB v4)
# MUST be exactly 16, 24, or 32 bytes (128, 192, or 256-bit AES)
# Required outside dev when using the Badger path.
# NEVER commit a real key to version control.
VELARIX_ENCRYPTION_KEY=

# Shared-store backend.
# Uncomment when VELARIX_STORE_BACKEND=postgres.
# VELARIX_POSTGRES_DSN=postgres://user:pass@localhost:5432/velarix?sslmode=disable
# VELARIX_REDIS_URL=redis://localhost:6379/0
# VELARIX_REDIS_ADDR=localhost:6379

# Required outside dev for JWT console auth.
VELARIX_JWT_SECRET=

# Port for the Go server
PORT=8080

# Optional runtime tuning.
VELARIX_MAX_CONCURRENT_WRITES=256
VELARIX_RETENTION_SWEEP_INTERVAL_MINUTES=60
# VELARIX_ALLOWED_ORIGINS=http://localhost:3000
# VELARIX_ADMIN_EMAIL=admin@example.com

# (Python SDK Only) The URL of your Velarix server
# Defaults to http://localhost:8080 if not set.
VELARIX_BASE_URL=http://localhost:8080
