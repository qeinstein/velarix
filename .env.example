# Velarix Environment Configuration
# ---------------------------------
# This file contains the environment variables required to run both the
# Open Source Core Engine and the Proprietary Control Plane.
# Comments call out which keys are required in production and why.

# ==========================================
# 1. CORE ENGINE (Open Source)
# ==========================================
PORT=8080
VELARIX_ENV=dev
# Reason: use `prod` outside local/dev to enable stricter runtime checks.

# Set to 'true' to bypass authentication and use local BadgerDB
VELARIX_LITE=false

# Storage Configuration (ignored if VELARIX_LITE=true)
VELARIX_STORE_BACKEND=postgres
# Required in production unless you explicitly opt into local Badger.
# Reason: Postgres is the durable shared system of record.
# sslmode must be set to 'require' or 'verify-full' in any non-local deployment.
# Using sslmode=disable transmits credentials in plaintext and must never be used outside a trusted local network.
VELARIX_POSTGRES_DSN=postgres://user:password@localhost:5432/velarix?sslmode=require

# Strongly recommended in production when running more than one instance.
# Reason: shared rate limiting and idempotency coordination across the fleet.
VELARIX_REDIS_URL=redis://localhost:6379

# Only set this to `true` if you intentionally want production to run on Badger.
# Reason: production now blocks silent fallback to local-only storage.
VELARIX_ALLOW_BADGER_PROD=false

# Security
# Required in production if using Badger.
# Reason: encryption at rest for the local embedded store.
VELARIX_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Required in production.
# Reason: signs console JWTs and decision execution tokens.
VELARIX_JWT_SECRET=super_secret_jwt_signing_key_change_in_prod

# Required in production when auth cookies are enabled.
# Reason: CORS now fails closed unless allowed origins are explicitly listed.
VELARIX_ALLOWED_ORIGINS=https://app.yourdomain.com

# Optional, but set this when the web app is on a different parent domain.
# Reason: controls the auth cookie domain for browser sessions.
VELARIX_AUTH_COOKIE_DOMAIN=

# Optional. Defaults to `Strict`.
# Reason: controls browser cross-site cookie behavior.
VELARIX_AUTH_COOKIE_SAMESITE=Strict

# Optional. Set to `true` to require explicit bearer tokens and disable auth cookies.
VELARIX_DISABLE_AUTH_COOKIES=false

# Optional. Keep `false` unless requests come through a trusted reverse proxy.
# Reason: only then should Velarix trust `X-Forwarded-For` and `X-Real-Ip`.
VELARIX_TRUST_PROXY_HEADERS=false

# Optional break-glass bootstrap admin path.
# Reason: the env admin key is disabled in production unless this is explicitly true.
VELARIX_ENABLE_BOOTSTRAP_ADMIN_KEY=false

# Optional. Only useful if bootstrap admin is enabled.
# Reason: one emergency admin bearer token for bootstrapping or recovery.
VELARIX_API_KEY=

# Optional. Defaults to 24.
# Reason: controls how long idempotent write responses can be replayed.
VELARIX_IDEMPOTENCY_TTL_HOURS=24

# Optional. Signs decision execution tokens independently of the console JWT secret.
# Must be at least 32 bytes if set. Defaults to VELARIX_JWT_SECRET if unset.
VELARIX_DECISION_TOKEN_SECRET=

# Optional. Path to BadgerDB data directory.
# Defaults to "velarix.data" in the working directory.
VELARIX_BADGER_PATH=velarix.data

# Optional. Set to "true" to disable Redis even when VELARIX_REDIS_URL is set.
VELARIX_DISABLE_REDIS=false

# Optional. Max concurrent write requests. Defaults to a conservative internal limit.
VELARIX_MAX_CONCURRENT_WRITES=

# Optional. CIDR block allowed to access the /metrics endpoint.
# If unset, the server defaults to localhost-only access.
VELARIX_METRICS_ALLOWED_CIDR=127.0.0.1/32

# Optional. Override the OpenAI API base URL used by the extract-and-assert endpoint.
# Defaults to the official OpenAI endpoint.
VELARIX_OPENAI_BASE_URL=

# Optional. OpenAI API key for extract-and-assert LLM calls.
OPENAI_API_KEY=

# Optional. Override the model used by both extract-and-assert and the consistency verifier.
VELARIX_VERIFIER_MODEL=

# Optional. Max fact pairs evaluated by the consistency verifier per run.
VELARIX_VERIFIER_MAX_PAIRS=

# Optional. Interval in minutes between retention sweeps.
VELARIX_RETENTION_SWEEP_INTERVAL_MINUTES=

# Optional. Velarix API base URL (used by internal tooling and the vlx CLI).
VELARIX_BASE_URL=http://localhost:8080

# Optional. SMTP settings for email notifications (e.g. invitation emails).
VELARIX_SMTP_ADDR=
VELARIX_SMTP_FROM=
VELARIX_SMTP_USER=
VELARIX_SMTP_PASS=

# Optional console bootstrap metadata.
# Reason: initial admin identity for first-party console flows.
VELARIX_ADMIN_EMAIL=admin@yourdomain.com

# ==========================================
# 2. FRONTEND APP (Web)
# ==========================================
# Point this to your hosted Go cluster (e.g. https://api.velarix.com)
# Reason: the browser app uses cookie-based auth against this API origin.
# Optional. Paths to TLS certificate and key files. If both are set, the server uses HTTPS.
# If neither is set, a prominent warning is logged and HTTP (plaintext) is used.
# Do NOT leave unset in production.
VELARIX_TLS_CERT=
VELARIX_TLS_KEY=

NEXT_PUBLIC_VELARIX_API_URL=https://localhost:8080

# Required only if you use Stripe-backed billing UI.
# Reason: publishable key for browser checkout/customer portal flows.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ==========================================
# 3. CONTROL PLANE (Billing & Infra)
# ==========================================
BILLING_PORT=8081

# Required in production for billing webhook verification and Stripe API access.
# Reason: billing service will fail closed outside dev/test without these.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
