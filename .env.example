# Velarix Environment Variables

# The secret key for your Velarix instance (for administrative routes)
VELARIX_API_KEY=vx_your_admin_secret_here

# Encryption at Rest (BadgerDB v4)
# MUST be exactly 16, 24, or 32 bytes (128, 192, or 256-bit AES)
# NEVER commit this to version control.
VELARIX_ENCRYPTION_KEY=

# Port for the Go server
PORT=8080
