{
  "basePath": "/",
  "definitions": {
    "api.GenerateKeyRequest": {
      "properties": {
        "email": {
          "example": "user@example.com",
          "type": "string"
        },
        "label": {
          "example": "Production",
          "type": "string"
        }
      },
      "type": "object"
    },
    "api.LoginRequest": {
      "properties": {
        "email": {
          "example": "user@example.com",
          "type": "string"
        },
        "password": {
          "example": "securepassword123",
          "type": "string"
        }
      },
      "type": "object"
    },
    "api.RegisterRequest": {
      "properties": {
        "email": {
          "example": "user@example.com",
          "type": "string"
        },
        "password": {
          "example": "securepassword123",
          "type": "string"
        }
      },
      "type": "object"
    },
    "api.ResetConfirmRequest": {
      "properties": {
        "email": {
          "example": "user@example.com",
          "type": "string"
        },
        "new_password": {
          "example": "newsecurepassword456",
          "type": "string"
        },
        "token": {
          "example": "a1b2c3",
          "type": "string"
        }
      },
      "type": "object"
    },
    "api.ResetRequest": {
      "properties": {
        "email": {
          "example": "user@example.com",
          "type": "string"
        }
      },
      "type": "object"
    },
    "api.sessionInfo": {
      "properties": {
        "id": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "core.ExplanationNode": {
      "properties": {
        "children": {
          "items": {
            "$ref": "#/definitions/core.ExplanationNode"
          },
          "type": "array"
        },
        "factID": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "core.Fact": {
      "properties": {
        "id": {
          "type": "string"
        },
        "idom": {
          "description": "Dominator Tree",
          "type": "string"
        },
        "justification_sets": {
          "description": "OR-of-AND justification (for API/Journal backwards compatibility)",
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "array"
        },
        "metadata": {
          "additionalProperties": true,
          "description": "Internal system metadata (ignored by schema validation)",
          "type": "object"
        },
        "payload": {
          "additionalProperties": true,
          "description": "Arbitrary belief payload (validated against user schema)",
          "type": "object"
        },
        "postOrder": {
          "type": "integer"
        },
        "preOrder": {
          "type": "integer"
        },
        "validation_errors": {
          "description": "Schema Validation",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "resolved_status": {
          "type": "number",
          "format": "float64"
        },
        "is_root": {
          "type": "boolean"
        },
        "manual_status": {
          "type": "number",
          "format": "float64"
        },
        "derived_status": {
          "type": "number",
          "format": "float64"
        },
        "valid_justification_count": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "core.ImpactReport": {
      "properties": {
        "action_count": {
          "type": "integer"
        },
        "direct_count": {
          "type": "integer"
        },
        "epistemic_loss": {
          "type": "number"
        },
        "impacted_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "total_count": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "store.APIKey": {
      "properties": {
        "created_at": {
          "type": "integer"
        },
        "is_revoked": {
          "type": "boolean"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "last_used_at": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "store.EventType": {
      "enum": [
        "assert",
        "invalidate",
        "cycle_violation",
        "snapshot_corruption",
        "confidence_adjusted",
        "revalidation_complete"
      ],
      "type": "string",
      "x-enum-varnames": [
        "EventAssert",
        "EventInvalidate",
        "EventCycleViolation",
        "EventSnapshotCorruption",
        "EventConfidenceAdjusted",
        "EventRevalidationComplete"
      ]
    },
    "store.JournalEntry": {
      "properties": {
        "fact": {
          "$ref": "#/definitions/core.Fact"
        },
        "fact_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "timestamp": {
          "type": "integer"
        },
        "type": {
          "$ref": "#/definitions/store.EventType"
        }
      },
      "type": "object"
    }
  },
  "host": "localhost:8080",
  "info": {
    "contact": {
      "email": "support@velarix.dev",
      "name": "API Support",
      "url": "http://velarix.dev/support"
    },
    "description": "The Epistemic State Layer for AI Agents.",
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "termsOfService": "http://velarix.dev/terms/",
    "title": "Velarix API",
    "version": "0.1.0"
  },
  "paths": {
    "/v1/auth/login": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "description": "Authenticate user and return a JWT for console access. No authentication required.",
        "parameters": [
          {
            "description": "Login credentials",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/api.LoginRequest"
            }
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "token",
            "schema": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "401": {
            "description": "invalid credentials",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Login user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/register": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "description": "Create a new user account with Argon2id password hashing. No authentication required.",
        "parameters": [
          {
            "description": "Registration details",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/api.RegisterRequest"
            }
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "201": {
            "description": "user created",
            "schema": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "400": {
            "description": "invalid request",
            "schema": {
              "type": "string"
            }
          },
          "500": {
            "description": "internal error",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/reset-confirm": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "description": "Update password using a reset token provided via console logs. No authentication required.",
        "parameters": [
          {
            "description": "Reset details",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/api.ResetConfirmRequest"
            }
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "status",
            "schema": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "401": {
            "description": "invalid token",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Confirm password reset",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/reset-request": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "description": "Generate a reset token and log it to the server console. No authentication required.",
        "parameters": [
          {
            "description": "User email",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/api.ResetRequest"
            }
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "status",
            "schema": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          }
        },
        "summary": "Request password reset",
        "tags": [
          "Auth"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Basic status, version, and uptime for monitoring.",
        "responses": {
          "200": {
            "description": "health status",
            "schema": {
              "additionalProperties": true,
              "type": "object"
            }
          }
        },
        "summary": "System health check",
        "tags": [
          "System"
        ]
      }
    },
    "/v1/keys": {
      "get": {
        "consumes": [
          "application/json"
        ],
        "description": "Retrieve all API keys associated with the user.",
        "parameters": [
          {
            "description": "User Email",
            "example": "\"user@example.com\"",
            "in": "query",
            "name": "email",
            "required": true,
            "type": "string"
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "items": {
                "$ref": "#/definitions/store.APIKey"
              },
              "type": "array"
            }
          },
          "401": {
            "description": "unauthorized",
            "schema": {
              "type": "string"
            }
          },
          "404": {
            "description": "user not found",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "List API keys",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/keys/{key}": {
      "delete": {
        "consumes": [
          "application/json"
        ],
        "description": "Mark an API key as revoked. Revoked keys return 401.",
        "parameters": [
          {
            "description": "API Key",
            "example": "\"vx_12345\"",
            "in": "path",
            "name": "key",
            "required": true,
            "type": "string"
          },
          {
            "description": "User Email",
            "example": "\"user@example.com\"",
            "in": "query",
            "name": "email",
            "required": true,
            "type": "string"
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "status",
            "schema": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "401": {
            "description": "unauthorized",
            "schema": {
              "type": "string"
            }
          },
          "404": {
            "description": "key not found",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Revoke an API key",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/keys/generate": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "description": "Create a new labeled API key for the user.",
        "parameters": [
          {
            "description": "Key details",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/api.GenerateKeyRequest"
            }
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/store.APIKey"
            }
          },
          "400": {
            "description": "invalid request",
            "schema": {
              "type": "string"
            }
          },
          "404": {
            "description": "user not found",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Generate a new API key",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/org/usage": {
      "get": {
        "description": "Retrieve atomic metrics for the requesting organization.",
        "responses": {
          "200": {
            "description": "usage metrics",
            "schema": {
              "additionalProperties": {
                "format": "int64",
                "type": "integer"
              },
              "type": "object"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get organization usage",
        "tags": [
          "System"
        ]
      }
    },
    "/v1/s/{session_id}/events": {
      "get": {
        "description": "Server-Sent Events (SSE) stream for real-time belief updates.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "event stream",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Stream session events",
        "tags": [
          "Facts"
        ]
      }
    },
    "/v1/s/{session_id}/export": {
      "get": {
        "description": "Generate a CSV or PDF export of the session history with a SHA-256 verification hash.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Format: csv or pdf",
            "in": "query",
            "name": "format",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "exported file",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Export audit log",
        "tags": [
          "History"
        ]
      }
    },
    "/v1/s/{session_id}/facts": {
      "get": {
        "description": "Retrieve all facts, optionally filtering for only logically 'Valid' ones.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Only return valid facts",
            "in": "query",
            "name": "valid",
            "type": "boolean"
          }
        ],
        "responses": {
          "200": {
            "description": "list of facts",
            "schema": {
              "items": {
                "$ref": "#/definitions/core.Fact"
              },
              "type": "array"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "List all facts in a session",
        "tags": [
          "Facts"
        ]
      },
      "post": {
        "consumes": [
          "application/json"
        ],
        "description": "Add a new fact to the reasoning graph. If root, it is manual. If derived, it requires justification sets.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Fact definition",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/core.Fact"
            }
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "201": {
            "description": "fact created",
            "schema": {
              "$ref": "#/definitions/core.Fact"
            }
          },
          "400": {
            "description": "invalid request",
            "schema": {
              "type": "string"
            }
          },
          "403": {
            "description": "unauthorized",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Assert a new fact",
        "tags": [
          "Facts"
        ]
      }
    },
    "/v1/s/{session_id}/facts/{id}": {
      "get": {
        "description": "Retrieve a fact by its ID within a session.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Fact ID",
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "fact details",
            "schema": {
              "$ref": "#/definitions/core.Fact"
            }
          },
          "404": {
            "description": "fact not found",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get a single fact",
        "tags": [
          "Facts"
        ]
      }
    },
    "/v1/s/{session_id}/facts/{id}/impact": {
      "get": {
        "description": "Calculate the downstream effect of retracting a specific fact.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Fact ID",
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "impact report",
            "schema": {
              "$ref": "#/definitions/core.ImpactReport"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Analyze impact",
        "tags": [
          "Analysis"
        ]
      }
    },
    "/v1/s/{session_id}/facts/{id}/invalidate": {
      "post": {
        "description": "Manually invalidate a root premise, triggering a causal collapse of all dependents.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Fact ID",
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "status invalidated",
            "schema": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "403": {
            "description": "unauthorized",
            "schema": {
              "type": "string"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Invalidate a root fact",
        "tags": [
          "Facts"
        ]
      }
    },
    "/v1/s/{session_id}/facts/{id}/why": {
      "get": {
        "description": "Retrieve the justification tree for a specific fact.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Fact ID",
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "explanation tree",
            "schema": {
              "$ref": "#/definitions/core.ExplanationNode"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Explain a fact",
        "tags": [
          "Analysis"
        ]
      }
    },
    "/v1/s/{session_id}/history": {
      "get": {
        "description": "Retrieve the full chronological journal for a session.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "audit trail",
            "schema": {
              "items": {
                "$ref": "#/definitions/store.JournalEntry"
              },
              "type": "array"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get session history",
        "tags": [
          "History"
        ]
      },
      "post": {
        "description": "Manually append a custom event to the session's audit trail.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Event to append",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/store.JournalEntry"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "event appended",
            "schema": {
              "$ref": "#/definitions/store.JournalEntry"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Append to journal",
        "tags": [
          "History"
        ]
      }
    },
    "/v1/s/{session_id}/revalidate": {
      "post": {
        "description": "Clear the engine and replay the full journal through all validation rules. Returns an impact summary.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "revalidation summary",
            "schema": {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Revalidate entire session",
        "tags": [
          "Analysis"
        ]
      }
    },
    "/v1/s/{session_id}/slice": {
      "get": {
        "description": "Retrieve the logically valid subset of facts formatted for LLM consumption.",
        "parameters": [
          {
            "description": "Session ID",
            "in": "path",
            "name": "session_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Format: json or markdown",
            "in": "query",
            "name": "format",
